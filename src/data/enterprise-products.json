    {
      "id": "hami-ai-platform",
      "name": {
        "en": "HAMi AI Platform",
        "zh": "HAMi 平台版"
      },
      "tagline": {
        "en": "Enterprise heterogeneous compute scheduling & virtualization platform — includes everything in HAMi Enterprise plus GUI, multi-cluster observability, tenant quota and OpenAPI",
        "zh": "企业级异构算力集群调度、虚拟化平台 —— 包含 HAMi 企业版全部能力，叠加多集群一站式 GUI、可观测、租户配额、计量计费与 OpenAPI"
      },
      "description": {
        "en": "HAMi AI Platform is the full-stack control plane for heterogeneous compute clusters. It bundles HAMi Enterprise with multi-cluster GUI, end-to-end observability (cluster/app/GPU), enterprise tenant quota, billing, OpenAPI, and SLA support — for public-cloud marketplaces, mid-market and KA customers.",
        "zh": "HAMi 平台版是面向异构算力集群的全栈控制面。在 HAMi 企业版基础上叠加多集群一站式 GUI、集群/应用/GPU 三维度可观测、企业级租户配额、计量计费、OpenAPI 与 SLA 支持，面向公有云应用市场、中小腰部客户与 KA 客户。"
      },
      "logo": "/images/enterprise/hami-ai-platform-logo.svg",
      "category": "platform",
      "status": "ga",
      "tags": ["异构算力", "多集群", "调度", "资源池化", "租户隔离"],
      "docsUrl": "https://docs.dynamia.ai/hami-ai-platform",
      "githubRepo": "dynamia-ai/hami-ai-platform",
      "highlights": [
        {
          "iconName": "cube",
          "title": {
            "en": "Multi-cluster Federation",
            "zh": "多集群联邦"
          },
          "desc": {
            "en": "Pool resources across data centers and clouds with a single control plane.",
            "zh": "跨数据中心、跨云资源池化，单一控制面统一调度。"
          }
        },
        {
          "iconName": "chart",
          "title": {
            "en": "Tenant-aware Quota",
            "zh": "租户配额"
          },
          "desc": {
            "en": "Hierarchical quota, fair-share scheduling and chargeback reports.",
            "zh": "层级配额、公平调度、计费报表一站式打通。"
          }
        },
        {
          "iconName": "eye",
          "title": {
            "en": "Real-time Observability",
            "zh": "实时观测"
          },
          "desc": {
            "en": "GPU/NPU utilization, queue latency, SLO dashboards.",
            "zh": "GPU/NPU 利用率、排队延迟、SLO 仪表盘全链路可视。"
          }
        }
      ],
      "compatibility": {
        "kubernetes": [">= 1.24", "<= 1.31"],
        "os": ["RHEL 8/9", "Ubuntu 22.04", "Kylin V10", "openEuler 22.03"],
        "gpu": ["NVIDIA", "Ascend", "Hygon DCU", "Cambricon MLU", "Iluvatar"]
