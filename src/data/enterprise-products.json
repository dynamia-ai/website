      "id": "hami-enterprise",
      "name": {
        "en": "HAMi Enterprise",
        "zh": "HAMi 企业版"
      },
      "tagline": {
        "en": "Enterprise edition of HAMi — production-grade GPU virtualization built on the CNCF Sandbox project",
        "zh": "HAMi 企业版 —— 在开源 HAMi（CNCF Sandbox 项目）之上提供企业级 GPU 虚拟化能力"
      },
      "description": {
        "en": "HAMi Enterprise is the GPU-license-based enterprise edition of HAMi, focused on lifting GPU utilization from the open-source 40% to 70%+. It targets vertical-internet teams and channel partners that already operate a PaaS and need a hardened, supported HAMi.",
        "zh": "HAMi 企业版基于 GPU License 授权，把 GPU 利用率从社区版 40% 提升到 70%+，面向已有 PaaS、研发能力较强的垂直互联网客户与合作伙伴/代理商，提供生产级加固与企业级支持。"
      },
      "logo": "/images/enterprise/hami-enterprise-logo.svg",
      "category": "gpu-virtualization",
      "status": "ga",
      "tags": ["GPU 虚拟化", "vGPU", "K8s Device Plugin", "异构算力"],
      "docsUrl": "https://docs.dynamia.ai/hami-enterprise",
      "githubRepo": "dynamia-ai/hami-enterprise",
      "highlights": [
        {
          "iconName": "shield",
          "title": {
            "en": "Enterprise SLA",
            "zh": "企业级 SLA"
          },
          "desc": {
            "en": "24/7 support, hotfix delivery and long-term version maintenance.",
            "zh": "7×24 技术支持、热修复响应、长期版本维护。"
          }
        },
        {
          "iconName": "chip",
          "title": {
            "en": "Multi-vendor GPU",
            "zh": "多厂商 GPU 适配"
          },
          "desc": {
            "en": "NVIDIA, Ascend, MLU, Iluvatar, Hygon DCU and more.",
            "zh": "支持英伟达、昇腾、寒武纪、天数智芯、海光 DCU 等主流加速卡。"
          }
        },
        {
          "iconName": "lock",
          "title": {
            "en": "Hardened Security",
            "zh": "安全加固"
          },
          "desc": {
            "en": "Signed images, CVE patching pipeline and audit logs.",
            "zh": "镜像签名、CVE 修复流水线、完整审计日志。"
          }
        }
      ],
      "compatibility": {
        "kubernetes": [">= 1.24", "<= 1.31"],
        "os": ["RHEL 8/9", "Ubuntu 20.04/22.04", "Kylin V10", "openEuler 22.03"],
        "gpu": [
