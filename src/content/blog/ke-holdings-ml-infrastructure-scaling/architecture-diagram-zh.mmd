flowchart TD
    subgraph Left [资源分配架构]
        direction TB
        subgraph L_Business [业务层]
            direction LR
            B1[训练任务]
            B2[开发机]
            B3[推理应用]
        end

        subgraph L_Container [容器层]
            direction LR
            C1[GPU]:::blueBox
            C2[GPU 内存]:::yellowBox
        end

        subgraph L_Physical [物理层]
            direction LR
            P1[独占分配<br>Node]:::blueBox
            P2[独占分配<br>Node]:::blueBox
            P3[内存分配<br>Node]:::yellowBox
            P4[内存分配<br>Node]:::yellowBox
        end

        subgraph L_Plugin [Device Plugin]
            direction LR
            DP1[NVIDIA Device<br>Plugin]:::blueBox
            DP2[HAMi Device<br>Plugin]:::yellowBox
        end

        %% Left side relations
        L_Container --> L_Business
        P1 & P2 --> C1
        P3 & P4 --> C2
        P1 & P2 --> DP1
        P3 & P4 --> DP2
    end

    subgraph Right [调度与部署架构]
        direction TB
        subgraph R_Deploy [Deployment]
            direction LR
            D1[Deployment Group 1]
            D2[Deployment Group 2]
            D3[Deployment Group 3]
            D4[Deployment Group 4]
        end

        subgraph R_Sched [调度组件]
            direction LR
            S1[Scheduler]:::yellowBox
            S2[Webhook]:::yellowBox
            S3[libvgpu.so]:::yellowBox
        end

        subgraph R_Physical [物理层]
            N1["Node1<br>Annotation: GPU0 16GB<br>GPU1 16GB"]:::yellowBox
        end

        subgraph R_Hardware [硬件 / vGPU]
            direction LR
            subgraph G0 [GPU0]
                direction LR
                V1[vGPU]:::greenBox
                V2[vGPU]:::greenBox
                V3[vGPU]:::greenBox
            end
            subgraph G1 [GPU1]
                direction LR
                V4[vGPU]:::greenBox
                V5[vGPU]:::greenBox
                V6[vGPU]:::greenBox
            end
        end

        %% Right side relations
        D1 & D2 & D3 & D4 --> R_Sched
        R_Sched --> N1
        N1 --> G0
        N1 --> G1
    end

    %% Cross diagram relations
    DP2 -.->|HAMi 虚拟化映射| R_Hardware

    classDef blueBox fill:#d9e2f3,stroke:#4472c4,stroke-width:1px,color:#000
    classDef yellowBox fill:#fff2cc,stroke:#d6b656,stroke-width:1px,color:#000
    classDef greenBox fill:#e2efda,stroke:#70ad47,stroke-width:1px,color:#000
